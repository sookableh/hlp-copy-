import asyncio
import json
import logging
import time
from collections import deque
from datetime import datetime, timezone
from decimal import Decimal
from typing import Any, Dict, List, Optional, Set

import aiohttp

from hummingbot.connector.connector_base import ConnectorBase
from hummingbot.core.utils.async_utils import safe_ensure_future
from hummingbot.strategy.script_strategy_base import ScriptStrategyBase

# HLP Vault parent address on Hyperliquid
HLP_VAULT_ADDRESS = "0xdfc24b077bc1425ad1dea75bcb6f8158e10df303"
HYPERLIQUID_INFO_URL = "https://api.hyperliquid.xyz/info"
HYPERLIQUID_WS_URL = "wss://api.hyperliquid.xyz/ws"

# ---- CONFIG ----
# Coins to track (uppercase). Leave empty list [] for ALL coins.
COINS_TO_TRACK = ["SOL"]

# How often to poll positions via REST (seconds) — trades come instantly via WebSocket
POSITION_POLL_INTERVAL = 2

# How often to poll mark prices via REST (seconds)
PRICE_POLL_INTERVAL = 10

# Number of recent trades to show per coin
NUM_RECENT_TRADES = 10

# Notifications
NOTIFY_ON_POSITION_CHANGE = True
NOTIFY_ON_NEW_TRADE = True


class HlpVaultTracker(ScriptStrategyBase):
    """
    Information-only bot that tracks HLP vault positions on Hyperliquid.
    Uses Hyperliquid public API directly — no API keys needed.

    - Trades: INSTANT via WebSocket (subscribes to each child's fills)
    - Positions: Polled every 10s via REST
    - Does NOT place any orders.
    """
    markets = {"hyperliquid_perpetual": {"BTC-USD"}}

    def __init__(self, connectors: Dict[str, ConnectorBase], config=None):
        super().__init__(connectors, config)
        self._last_position_poll: float = 0
        self._last_price_poll: float = 0
        self._previous_positions: Dict[str, Dict[str, Any]] = {}
        self._last_seen_trade_time: Dict[str, int] = {}
        self._vault_positions: Dict[str, Dict[str, Any]] = {}
        self._recent_trades: Dict[str, List[Dict[str, Any]]] = {}
        self._child_addresses: List[str] = []
        self._vault_info: Dict[str, Any] = {}
        self._session: Optional[aiohttp.ClientSession] = None
        self._initialized: bool = False
        self._current_prices: Dict[str, float] = {}
        self._ws_started: bool = False
        self._ws_tasks: List[asyncio.Task] = []
        self._message_log: deque = deque(maxlen=20)

    async def _get_session(self) -> aiohttp.ClientSession:
        if self._session is None or self._session.closed:
            self._session = aiohttp.ClientSession()
        return self._session

    async def _api_request(self, payload: dict) -> Any:
        session = await self._get_session()
        try:
            async with session.post(
                HYPERLIQUID_INFO_URL,
                json=payload,
                headers={"Content-Type": "application/json"},
                timeout=aiohttp.ClientTimeout(total=15),
            ) as response:
                if response.status == 200:
                    return await response.json()
                else:
                    self.logger().error(f"HLP API error: {response.status}")
                    return None
        except Exception as e:
            self.logger().error(f"HLP API request failed: {e}")
            return None

    # ---- WebSocket for instant trade fills ----

    async def _run_ws_for_address(self, address: str):
        """Subscribe to a child address's fills via WebSocket for instant trade notifications."""
        while True:
            try:
                session = await self._get_session()
                async with session.ws_connect(HYPERLIQUID_WS_URL) as ws:
                    subscribe_msg = {
                        "method": "subscribe",
                        "subscription": {"type": "userFills", "user": address}
                    }
                    await ws.send_json(subscribe_msg)
                    self.logger().info(f"WS connected for child {address[:10]}...")

                    last_ping = time.time()
                    while True:
                        # Ping every 10 seconds to keep connection alive
                        now = time.time()
                        if now - last_ping >= 20:
                            await ws.send_json({"method": "ping"})
                            last_ping = now

                        try:
                            msg = await asyncio.wait_for(ws.receive(), timeout=5)
                        except asyncio.TimeoutError:
                            continue

                        if msg.type == aiohttp.WSMsgType.TEXT:
                            try:
                                raw = msg.data.replace("NaN", "null")
                                data = json.loads(raw)
                                if data.get("channel") == "pong":
                                    continue
                                self._handle_ws_fill(data)
                            except (json.JSONDecodeError, ValueError) as e:
                                self.logger().debug(f"WS parse error for {address[:10]}...: {e}")
                                continue
                        elif msg.type in (aiohttp.WSMsgType.CLOSED, aiohttp.WSMsgType.ERROR):
                            break
            except asyncio.CancelledError:
                return
            except Exception as e:
                self.logger().warning(f"WS disconnected for {address[:10]}...: {e}, reconnecting in 5s")
                await asyncio.sleep(5)

    def _build_table(self) -> str:
        """Build a compact positions table."""
        tracked = COINS_TO_TRACK if COINS_TO_TRACK else sorted(self._vault_positions.keys())
        lines = []
        lines.append(f"  {'Coin':<10} {'Side':<5} {'Size':>10} {'Value':>11} {'Entry':>11} {'Mark':>11} {'uPnL':>11}")
        lines.append(f"  {'─'*10} {'─'*5} {'─'*10} {'─'*11} {'─'*11} {'─'*11} {'─'*11}")
        for coin in tracked:
            pos = self._vault_positions.get(coin)
            if pos is None:
                lines.append(f"  {coin:<10} {'—':<5} {'—':>10} {'—':>11} {'—':>11} {'—':>11} {'—':>11}")
                continue
            mark = self._current_prices.get(coin)
            mark_val = f"${mark:,.2f}" if mark else "—"
            mark_str = f"{mark_val:>11}"
            entry_val = f"${pos['entry_price']:,.2f}"
            entry_str = f"{entry_val:>11}"
            pnl = pos['unrealized_pnl']
            pnl_val = f"${pnl:+,.2f}"
            pnl_str = f"{pnl_val:>11}"
            value_val = f"${pos['position_value']:,.2f}"
            value_str = f"{value_val:>11}"
            lines.append(
                f"  {coin:<10} {pos['side']:<5} {abs(pos['size']):>10.4f}"
                f" {value_str} {entry_str} {mark_str} {pnl_str}"
            )
        return "\n".join(lines)

    def _notify_with_table(self, message: str):
        """Add message to the buffer (shown in format_status) and log it."""
        self._message_log.append(message)
        self.logger().info(message)

    @staticmethod
    def _safe_float(val, default=0.0) -> float:
        """Parse a float value, returning default for None/NaN/invalid."""
        if val is None:
            return default
        try:
            f = float(val)
            if f != f:  # NaN check
                return default
            return f
        except (ValueError, TypeError):
            return default

    def _handle_ws_fill(self, data: dict):
        """Process a real-time fill from the WebSocket."""
        channel = data.get("channel")
        if channel != "userFills":
            return

        fills_data = data.get("data", {})
        if isinstance(fills_data, dict):
            fills_list = fills_data.get("fills", [])
        elif isinstance(fills_data, list):
            fills_list = fills_data
        else:
            return

        for fill in fills_list:
            coin = fill.get("coin", "")
            if COINS_TO_TRACK and coin not in COINS_TO_TRACK:
                continue

            trade = {
                "coin": coin,
                "side": "BUY" if fill.get("side") == "B" else "SELL",
                "price": self._safe_float(fill.get("px")),
                "size": self._safe_float(fill.get("sz")),
                "time": fill.get("time", int(time.time() * 1000)),
                "fee": self._safe_float(fill.get("fee")),
                "closed_pnl": self._safe_float(fill.get("closedPnl")),
                "direction": fill.get("dir", ""),
            }

            # Add to recent trades
            if coin not in self._recent_trades:
                self._recent_trades[coin] = []
            self._recent_trades[coin].insert(0, trade)
            self._recent_trades[coin] = self._recent_trades[coin][:NUM_RECENT_TRADES]
            self._last_seen_trade_time[coin] = trade["time"]

            # Instant notification with table
            if NOTIFY_ON_NEW_TRADE:
                ts = datetime.fromtimestamp(trade["time"] / 1000, tz=timezone.utc)
                self._notify_with_table(
                    f"[TRADE] {coin}: {trade['side']} {trade['size']:.4f} @ "
                    f"${trade['price']:.2f} | PnL: ${trade['closed_pnl']:.2f} | "
                    f"{trade['direction']} | {ts.strftime('%H:%M:%S UTC')}")

    async def _start_websockets(self):
        """Start WebSocket connections for all child addresses."""
        if self._ws_started:
            return
        self._ws_started = True
        for address in self._child_addresses:
            task = safe_ensure_future(self._run_ws_for_address(address))
            self._ws_tasks.append(task)
        self.logger().info(f"Started {len(self._child_addresses)} WebSocket feeds for instant trade updates")

    # ---- REST polling for positions and prices ----

    async def _discover_child_addresses(self):
        data = await self._api_request({
            "type": "vaultDetails",
            "vaultAddress": HLP_VAULT_ADDRESS,
        })
        if not data:
            self._child_addresses = [HLP_VAULT_ADDRESS]
            return

        self._vault_info = {
            "name": data.get("name", "HLP Vault"),
            "apr": data.get("apr"),
        }

        children = data.get("relationship", {}).get("data", {}).get("childAddresses", [])
        if children:
            self._child_addresses = children
            self.logger().info(f"HLP Vault has {len(children)} child sub-accounts")
        else:
            self._child_addresses = [HLP_VAULT_ADDRESS]

    async def _fetch_current_prices(self):
        data = await self._api_request({"type": "metaAndAssetCtxs"})
        if not data or len(data) < 2:
            return
        meta = data[0]
        contexts = data[1]
        for asset_info, ctx in zip(meta.get("universe", []), contexts):
            coin = asset_info.get("name", "")
            if COINS_TO_TRACK and coin not in COINS_TO_TRACK:
                continue
            mark_px = ctx.get("markPx")
            if mark_px:
                self._current_prices[coin] = float(mark_px)

    async def _fetch_positions_for_address(self, address: str) -> List[Dict[str, Any]]:
        data = await self._api_request({
            "type": "clearinghouseState",
            "user": address,
        })
        if data is None:
            return []

        positions = []
        for pos in data.get("assetPositions", []):
            item = pos.get("position", pos)
            coin = item.get("coin", "")
            szi = float(item.get("szi", 0))
            if szi == 0:
                continue
            positions.append({
                "coin": coin,
                "size": szi,
                "entry_price": float(item.get("entryPx", 0)),
                "position_value": float(item.get("positionValue", 0)),
                "unrealized_pnl": float(item.get("unrealizedPnl", 0)),
                "return_on_equity": float(item.get("returnOnEquity", 0)),
                "leverage_type": item.get("leverage", {}).get("type", "unknown"),
                "leverage_value": item.get("leverage", {}).get("value", 0),
                "liquidation_price": item.get("liquidationPx"),
                "margin_used": float(item.get("marginUsed", 0)),
            })
        return positions

    async def _fetch_all_positions(self) -> Dict[str, Dict[str, Any]]:
        all_positions: Dict[str, Dict[str, Any]] = {}

        for address in self._child_addresses:
            child_positions = await self._fetch_positions_for_address(address)
            for pos in child_positions:
                coin = pos["coin"]
                if COINS_TO_TRACK and coin not in COINS_TO_TRACK:
                    continue
                if coin in all_positions:
                    existing = all_positions[coin]
                    old_size = existing["size"]
                    new_size = old_size + pos["size"]
                    if abs(new_size) > 1e-10:
                        existing["entry_price"] = (
                            abs(old_size) * existing["entry_price"] +
                            abs(pos["size"]) * pos["entry_price"]
                        ) / (abs(old_size) + abs(pos["size"]))
                    existing["size"] = new_size
                    existing["position_value"] += pos["position_value"]
                    existing["unrealized_pnl"] += pos["unrealized_pnl"]
                    existing["margin_used"] += pos["margin_used"]
                else:
                    all_positions[coin] = {
                        "coin": coin,
                        "size": pos["size"],
                        "entry_price": pos["entry_price"],
                        "position_value": pos["position_value"],
                        "unrealized_pnl": pos["unrealized_pnl"],
                        "return_on_equity": pos["return_on_equity"],
                        "leverage_type": pos["leverage_type"],
                        "leverage_value": pos["leverage_value"],
                        "liquidation_price": pos["liquidation_price"],
                        "margin_used": pos["margin_used"],
                    }

        filtered = {}
        for coin, pos in all_positions.items():
            if abs(pos["size"]) < 1e-10:
                continue
            pos["side"] = "LONG" if pos["size"] > 0 else "SHORT"
            # Recalculate position_value from net size × mark price
            mark = self._current_prices.get(coin)
            if mark:
                pos["position_value"] = abs(pos["size"]) * mark
            filtered[coin] = pos
        return filtered

    def _detect_position_changes(self, new_positions: Dict[str, Dict[str, Any]]):
        """Detect position changes (trades are handled by WebSocket now)."""
        if not self._initialized:
            self._initialized = True
            return

        if not NOTIFY_ON_POSITION_CHANGE:
            return

        old_coins = set(self._previous_positions.keys())
        new_coins = set(new_positions.keys())

        for coin in new_coins - old_coins:
            pos = new_positions[coin]
            self._notify_with_table(
                f"[NEW POSITION] {coin}: {pos['side']} {abs(pos['size']):.4f} @ ${pos['entry_price']:.2f}")

        for coin in old_coins - new_coins:
            old_pos = self._previous_positions[coin]
            self._notify_with_table(
                f"[CLOSED] {coin}: was {old_pos['side']} {abs(old_pos['size']):.4f}")

        for coin in old_coins & new_coins:
            old_size = self._previous_positions[coin]["size"]
            new_size = new_positions[coin]["size"]
            if abs(new_size - old_size) / max(abs(old_size), 1e-10) > 0.01:
                direction = "INCREASED" if abs(new_size) > abs(old_size) else "DECREASED"
                self._notify_with_table(
                    f"[{direction}] {coin}: {abs(old_size):.4f} -> {abs(new_size):.4f}")

    async def _init_vault(self):
        """One-time init: discover children, start WS, fetch initial fills."""
        await self._discover_child_addresses()
        await self._start_websockets()
        await self._fetch_initial_fills()
        await self._fetch_current_prices()
        await self._poll_positions()

    async def _poll_positions(self):
        """Poll positions via REST every 2s."""
        new_positions = await self._fetch_all_positions()
        self._detect_position_changes(new_positions)
        self._previous_positions = self._vault_positions.copy()
        self._vault_positions = new_positions

    async def _fetch_initial_fills(self):
        """One-time REST fetch to populate recent trades history."""
        for address in self._child_addresses:
            data = await self._api_request({
                "type": "userFills",
                "user": address,
            })
            if data is None:
                continue
            for fill in data:
                coin = fill.get("coin", "")
                if COINS_TO_TRACK and coin not in COINS_TO_TRACK:
                    continue
                trade = {
                    "coin": coin,
                    "side": "BUY" if fill.get("side") == "B" else "SELL",
                    "price": float(fill.get("px", 0)),
                    "size": float(fill.get("sz", 0)),
                    "time": fill.get("time", 0),
                    "fee": float(fill.get("fee", 0)),
                    "closed_pnl": float(fill.get("closedPnl", 0)),
                    "direction": fill.get("dir", ""),
                }
                if coin not in self._recent_trades:
                    self._recent_trades[coin] = []
                self._recent_trades[coin].append(trade)

        # Sort and trim
        for coin in self._recent_trades:
            self._recent_trades[coin].sort(key=lambda x: x["time"], reverse=True)
            self._recent_trades[coin] = self._recent_trades[coin][:NUM_RECENT_TRADES]
            if self._recent_trades[coin]:
                self._last_seen_trade_time[coin] = self._recent_trades[coin][0]["time"]

    def on_tick(self):
        now = time.time()

        # One-time init
        if not self._child_addresses:
            self._last_position_poll = now
            self._last_price_poll = now
            safe_ensure_future(self._init_vault())
            return

        # Positions every 2s (weight 2 × 7 children = 14 per poll)
        if now - self._last_position_poll >= POSITION_POLL_INTERVAL:
            self._last_position_poll = now
            safe_ensure_future(self._poll_positions())

        # Prices every 10s (weight 20)
        if now - self._last_price_poll >= PRICE_POLL_INTERVAL:
            self._last_price_poll = now
            safe_ensure_future(self._fetch_current_prices())

    def format_status(self) -> str:
        lines = []
        tracked = COINS_TO_TRACK if COINS_TO_TRACK else sorted(self._vault_positions.keys())
        vault_name = self._vault_info.get("name", "HLP Vault")
        apr = self._vault_info.get("apr")
        apr_str = f" | APR: {float(apr) * 100:.2f}%" if apr else ""
        ws_status = "LIVE" if self._ws_started else "starting..."

        lines.append(f"  {vault_name}{apr_str} | WS: {ws_status}")
        lines.append("")

        if not self._vault_positions:
            lines.append("  Waiting for data...")
            return "\n".join(lines)

        lines.append(f"  {'Coin':<10} {'Side':<5} {'Size':>10} {'Value':>11} {'Entry':>11} {'Mark':>11} {'uPnL':>11}")
        lines.append(f"  {'─'*10} {'─'*5} {'─'*10} {'─'*11} {'─'*11} {'─'*11} {'─'*11}")

        for coin in tracked:
            pos = self._vault_positions.get(coin)
            if pos is None:
                lines.append(f"  {coin:<10} {'—':<5} {'—':>10} {'—':>11} {'—':>11} {'—':>11} {'—':>11}")
                continue
            mark = self._current_prices.get(coin)
            mark_val = f"${mark:,.2f}" if mark else "—"
            mark_str = f"{mark_val:>11}"
            entry_val = f"${pos['entry_price']:,.2f}"
            entry_str = f"{entry_val:>11}"
            pnl = pos['unrealized_pnl']
            pnl_val = f"${pnl:+,.2f}"
            pnl_str = f"{pnl_val:>11}"
            value_val = f"${pos['position_value']:,.2f}"
            value_str = f"{value_val:>11}"
            lines.append(
                f"  {coin:<10} {pos['side']:<5} {abs(pos['size']):>10.4f}"
                f" {value_str} {entry_str} {mark_str} {pnl_str}"
            )

        # Separator + recent messages
        lines.append(f"\n  {'─'*55}")
        for msg in self._message_log:
            lines.append(f"  {msg}")

        return "\n".join(lines)
